# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Meta/Facebook API Configuration (for future integration)
META_API_ACCESS_TOKEN=your_meta_api_token_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

# Stability AI API (for advanced image generation)
STABILITY_AI_API_KEY=your_stability_ai_key_here

# OpenAI API (alternative LLM option)
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
MAX_CONCURRENT_REQUESTS=10
